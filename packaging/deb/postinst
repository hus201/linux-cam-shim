#!/bin/sh
set -e

case "$1" in
    configure)
        mkdir -p /var/lib/cam-shim
        chmod 755 /var/lib/cam-shim
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload || true
        fi
        echo ""
        echo "cam-shim installed."
        echo "  Scan cameras:     cam-shim scan"
        echo "  Run daemon:       sudo cam-shim serve"
        echo ""
        echo "A systemd unit is installed but not enabled (serve is still early-stage)."
        echo "After you have validated your setup, you can opt in with:"
        echo "  sudo systemctl enable --now cam-shim"
        echo ""
        echo "cam-shim loads v4l2loopback itself (exclusive_caps=1, devices=0)."
        echo "No /etc/modprobe.d configuration is required."
        echo ""
        echo "Many recent kernels include v4l2loopback in-tree — you may not need"
        echo "v4l2loopback-dkms. Do not install the Ubuntu DKMS package on kernel 7.x"
        echo "unless you know you need it; it often fails to build."
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

esac

#DEBHELPER#

exit 0
